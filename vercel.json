{
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "description": "The public URL of your site",
      "value": ""
    },
    {
      "key": "NEXT_PUBLIC_BASE_URL",
      "description": "The base URL for API calls",
      "value": ""
    },
    {
      "key": "NEXT_PUBLIC_WHATSAPP_NUMBER",
